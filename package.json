{
  "name": "chatwrapped",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "WhatsApp Wrapped — cinematic recap of your group chat year. 100% client-side.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "theme": "node scripts/apply-theme.js",
    "sync": "npm run build && npx cap sync",
    "watch": "vite build --watch",
    "android": "npm run sync && npx cap open android",
    "ios": "npm run sync && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/share": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "vite": "^5.4.10"
  }
}
