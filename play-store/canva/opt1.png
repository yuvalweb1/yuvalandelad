093E\u0930\u093E <a href="${e}">\u0938\u094D\u091F\u0947\u091F\u0938 \u092A\u0947\u091C</a> \u0926\u0947\u0916\u0947\u0902\u0964`,geo_title:"\u0939\u092E \u0906\u092A\u0915\u094B Canva \u0938\u0947 \u0915\u0928\u0947\u0915\u094D\u091F \u0928\u0939\u0940\u0902 \u0915\u0930 \u0938\u0915\u0924\u0947",geo_subtitle:"\u0905\u0902\u0924\u0930\u094D\u0930\u093E\u0937\u094D\u091F\u094D\u0930\u0940\u092F \u092A\u094D\u0930\u0924\u093F\u092C\u0902\u0927\u094B\u0902 \u0915\u0940 \u0935\u091C\u0939 \u0938\u0947, Canva \u0915\u094B \u092B\u093C\u093F\u0932\u0939\u093E\u0932 \u0906\u092A\u0915\u0947 \u0932\u094B\u0915\u0947\u0936\u0928 \u0938\u0947 \u0910\u0915\u094D\u0938\u0947\u0938 \u0928\u0939\u0940\u0902 \u0915\u093F\u092F\u093E \u091C\u093E \u0938\u0915\u0924\u093E\u0964",waf_title:"\u0939\u092E \u0906\u092A\u0915\u094B Canva \u0938\u0947 \u0915\u0928\u0947\u0915\u094D\u091F \u0928\u0939\u0940\u0902 \u0915\u0930 \u0938\u0915\u0924\u0947",waf_subtitle:`\u0905\u0917\u0930 \u0938\u092E\u0938\u094D\u092F\u093E \u0906\u0917\u0947 \u092D\u0940 \u091C\u093E\u0930\u0940 \u0930\u0939\u0924\u0940 \u0939\u0948, \u0924\u094B \u0928\u0940\u091A\u0947 \u0926\u0940 \u0917\u0908 \u091C\u093E\u0928\u0915\u093E\u0930\u0940 \u0915\u0947 \u0938\u093E\u0925 <a href="${t}">Canva \u0938\u092A\u094B\u0930\u094D\u091F</a> \u0938\u0947 \u0938\u0902\u092A\u0930\u094D\u0915 \u0915\u0930\u0947\u0902\u0964`,"500s_title":"\u0906\u092A \u091C\u0932\u094D\u0926 \u0939\u0940 \u0921\u093F\u091C\u093C\u093E\u0907\u0928 \u092C\u0928\u093E\u0928\u093E \u0936\u0941\u0930\u0942 \u0915\u0930 \u0938\u0915\u0947\u0902\u0917\u0947/\u0938\u0915\u0947\u0902\u0917\u0940","500s_subtitle":`\u0939\u092E\u093E\u0930\u093E \u0938\u0941\u091D\u093E\u0935 \u0939\u0948 \u0915\u093F \u0906\u092A \u0915\u0941\u091B \u0926\u0947\u0930 \u0907\u0902\u0924\u091C\u093C\u093E\u0930 \u0915\u0930\u0947\u0902 \u0914\u0930 \u092B\u093F\u0930 \u092A\u0947\u091C \u0915\u094B \u0930\u0940\u092B\u093C\u094D\u0930\u0947\u0936 \u0915\u0930\u0947\